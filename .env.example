# GitHub API token for fetching issues (optional, increases rate limit)
GITHUB_TOKEN=

# PostgreSQL connection (set automatically by Docker Compose in production)
DATABASE_URL=postgresql://aispeg:aispeg_secret@localhost:5432/aispeg

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_DB=aispeg
POSTGRES_USER=aispeg
POSTGRES_PASSWORD=aispeg_secret

# Basic auth for /internal/* (Sprint 2 — replace with UI SSO later)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
